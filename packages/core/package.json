{
  "name": "@cloud-icons/core",
  "version": "0.0.2",
  "description": "Cloud provider icons — framework-agnostic SVG content and metadata",
  "license": "MIT",
  "author": "fabiog96",
  "homepage": "https://github.com/fabiog96/cloud-icons#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/fabiog96/cloud-icons",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/fabiog96/cloud-icons/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./aws": {
      "types": "./dist/aws/index.d.ts",
      "import": "./dist/aws/index.js",
      "require": "./dist/aws/index.cjs"
    },
    "./azure": {
      "types": "./dist/azure/index.d.ts",
      "import": "./dist/azure/index.js",
      "require": "./dist/azure/index.cjs"
    },
    "./gcp": {
      "types": "./dist/gcp/index.d.ts",
      "import": "./dist/gcp/index.js",
      "require": "./dist/gcp/index.cjs"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js",
      "require": "./dist/metadata.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.4.0"
  },
  "keywords": [
    "icons",
    "cloud",
    "aws",
    "azure",
    "gcp",
    "svg"
  ]
}

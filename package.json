{
  "name": "cloud-icons",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "icons:download": "tsx scripts/download.ts",
    "icons:cleanup": "tsx scripts/cleanup.ts",
    "icons:optimize": "tsx scripts/optimize.ts",
    "icons:generate": "tsx scripts/generate.ts",
    "icons:pipeline": "npm run icons:download && npm run icons:cleanup && npm run icons:optimize && npm run icons:generate",
    "build:packages": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "lint": "eslint .",
    "demo": "npm run dev --workspace=demo"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "eslint": "^9.15.0",
    "jsdom": "^29.1.1",
    "svgo": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
